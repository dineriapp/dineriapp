generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  USER
  ADMIN
}

model User {
  id String @id @default(uuid()) @db.Uuid

  name          String    @default("Full Name")
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  phone         String?
  role          Role      @default(USER)
  banned        Boolean   @default(false)
  banReason     String?
  banExpires    DateTime?

  //new
  subscription_plan                 SubscriptionPlan   @default(basic)
  subscription_status               SubscriptionStatus @default(inactive)
  stripe_customer_id                String?
  stripe_subscription_id            String?
  restaurants                       Restaurant[]
  subscription_current_period_start DateTime?          @db.Timestamptz
  subscription_current_period_end   DateTime?          @db.Timestamptz
  Order                             Order[]

  sessions Session[]
  accounts Account[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@map("users")
}

model Session {
  id        String   @id @default(uuid())
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  token          String  @unique
  ipAddress      String?
  userAgent      String?
  userId         String  @db.Uuid
  impersonatedBy String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accountId             String
  providerId            String
  userId                String    @db.Uuid
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("accounts")
}

model Verification {
  id        String    @id @default(uuid())
  expiresAt DateTime
  createdAt DateTime?
  updatedAt DateTime?

  identifier String
  value      String

  @@map("verifications")
}

enum ButtonStyle {
  rounded
  square
  pill
}

enum BgType {
  color
  gradient
  image
}

enum GradientDirection {
  top
  bottom
  left
  right
  top_right
  top_left
  bottom_right
  bottom_left
}

enum ButtonVariant {
  solid
  outline
}

enum PaymentStatus {
  pending
  completed
  failed
  refunded
}

enum SocialIconsPosition {
  top
  bottom
}

enum SubscriptionPlan {
  basic
  pro
  enterprise
}

enum SubscriptionStatus {
  active
  inactive
  past_due
}

enum OrderStatus {
  pending
  confirmed
  preparing
  ready
  delivered
  cancelled
}

enum RestaurantStatus {
  DISABLE_DELIVERY
  DISABLE_PICKUP
  DISABLE_BOTH
  ALLOKAY
}

model Restaurant {
  id                               String              @id @default(uuid()) @db.Uuid
  user_id                          String              @db.Uuid
  name                             String
  bio                              String?             @default("")
  locations                        String[]            @default([])
  logo_url                         String?
  bg_color                         String?             @default("#ffffff")
  accent_color                     String?             @default("#10b981")
  headings_text_color              String?             @default("#000000")
  button_text_icons_color          String?             @default("#000000")
  button_style                     ButtonStyle         @default(rounded)
  button_icons_show                Boolean             @default(true)
  buttons_gap_in_px                Int                 @default(16)
  font_family                      String?             @default("var(--font-inter)")
  bg_type                          BgType              @default(color)
  bg_gradient_start                String?             @default("#ffffff")
  bg_gradient_end                  String?             @default("#f3f4f6")
  gradient_direction               GradientDirection   @default(bottom_right)
  button_variant                   ButtonVariant       @default(solid)
  status                           RestaurantStatus    @default(ALLOKAY)
  slug                             String              @unique
  delivery_fee                     Float               @default(5.0)
  tax_percentage                   Float               @default(8.0)
  address                          String?
  phone                            String?
  email                            String?
  instagram                        String?
  facebook                         String?
  whatsapp                         String?
  tiktok                           String?
  social_icons_position            SocialIconsPosition @default(top)
  social_icon_bg_show              Boolean             @default(false)
  social_icon_bg_color             String              @default("#FFFFFF")
  social_icon_color                String              @default("#000000")
  social_icon_gap                  Int                 @default(12)
  opening_hours                    Json?               @default("{\"monday\":{\"open\":\"\",\"close\":\"\",\"closed\":true},\"tuesday\":{\"open\":\"\",\"close\":\"\",\"closed\":true},\"wednesday\":{\"open\":\"\",\"close\":\"\",\"closed\":true},\"thursday\":{\"open\":\"\",\"close\":\"\",\"closed\":true},\"friday\":{\"open\":\"\",\"close\":\"\",\"closed\":true},\"saturday\":{\"open\":\"\",\"close\":\"\",\"closed\":true},\"sunday\":{\"open\":\"\",\"close\":\"\",\"closed\":true}}")
  timezone                         String?             @default("Europe/Rome")
  latitude                         Float?
  longitude                        Float?
  review_count                     Int?                @default(0)
  average_rating                   Float?
  google_place_id                  String?
  bg_image_url                     String?
  welcome_popup_enabled            Boolean?            @default(true)
  welcome_popup_message            String?             @default("Welcome! We're excited to have you visit us.")
  welcome_popup_delay              Int?                @default(2)
  welcome_popup_action_button_show Boolean?            @default(true)
  welcome_popup_show_info          Json?               @default("{\"hours\": true, \"phone\": true, \"address\": true, \"ratings\": true}")
  menu_popup_enabled               Boolean?            @default(true)
  menu_popup_message               String?             @default("Welcome! We're excited to have you visit us.")
  menu_popup_delay                 Int?                @default(2)
  menu_popup_action_button_show    Boolean?            @default(true)
  menu_popup_show_info             Json?               @default("{\"hours\": true, \"phone\": true, \"address\": true, \"ratings\": true}")
  event_announcements_enabled      Boolean?            @default(true)
  event_announcement_days          Int?                @default(30)
  max_events_in_popup              Int?                @default(3)
  event_rotation_speed             Int?                @default(5)
  welcome_popup_show_button        Boolean?            @default(true)
  menu_popup_show_button           Boolean?            @default(true)
  createdAt                        DateTime            @default(now()) @map("created_at")
  updatedAt                        DateTime            @default(now()) @updatedAt @map("updated_at")
  // Stripe keys encrypted 
  stripe_public_key_encrypted      String?
  stripe_secret_key_encrypted      String?
  stripe_webhook_secret_encrypted  String?

  //Menu Page Customizations
  menuPageBackgroundImage String @default("data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAABQAAAAOCAYAAACp8Z5+AAAAHUlEQVR42mP8z8Dwn4EIwDiqBQjRAxA0DA4jCAEAzB0KCUo9S5YAAAAASUVORK5CYII=")

  // Header
  headerBg                    String @default("white")
  headerText                  String @default("black")
  headerCartButtonBG          String @default("white")
  headerCartButtonBorder      String @default("#ebebeb")
  headerCartButtonCountBG     String @default("white")
  headerCartButtonCountBorder String @default("#ebebeb")

  // Overall
  textColor      String @default("black")
  bgColor        String @default("#f9fafb")
  infoIconsColor String @default("#fdc700")

  // Category Tabs
  tabsButtonBG         String @default("black")
  tabsButtonDefault    String @default("white")
  tabsBorderColor      String @default("transparent")
  tabsTextColor        String @default("white")
  tabsTextDefaultColor String @default("black")

  // Cards
  cardsBG              String @default("white")
  cardsText            String @default("black")
  cardsBadgesBg        String @default("#F5F5F5")
  cardsBadgesTextColor String @default("black")

  events               Event[]
  faqCategories        FaqCategory[]
  links                Link[]
  menuCategories       MenuCategory[]
  reviews              Review[]
  user                 User                 @relation(fields: [user_id], references: [id], onDelete: Cascade)
  restaurantViews      RestaurantView[]
  qrCodes              qr_codes[]
  Order                Order[]
  tables               Table[]
  Area                 Area[]
  Reservation          Reservation[]
  // reservation settings
  reservation_settings ReservationSettings?
  reservationQuery     ReservationQuery[]
  Reservation_policy   ReservationPolicy?

  @@index([user_id])
  @@index([slug])
  @@index([createdAt])
  @@map("restaurants")
}

model ReservationPolicy {
  id String @id @default(cuid())

  restaurant_id String     @unique @db.Uuid
  restaurant    Restaurant @relation(fields: [restaurant_id], references: [id], onDelete: Cascade)

  // --- FOUR POLICY FIELDS WITH HTML DEFAULTS ---
  cancellation_policy  String  @default("<p>No cancellation policy added yet.</p>") @db.Text
  cancellation_enabled Boolean @default(true)

  deposit_policy  String  @default("<p>No deposit policy added yet.</p>") @db.Text
  deposit_enabled Boolean @default(true)

  dining_policy  String  @default("<p>No dining policy added yet.</p>") @db.Text
  dining_enabled Boolean @default(true)

  no_show_policy  String  @default("<p>No show policy added yet.</p>") @db.Text
  no_show_enabled Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("reservation_policy")
}

model ReservationSettings {
  id            String     @id @default(cuid())
  restaurant_id String     @unique @db.Uuid
  restaurant    Restaurant @relation(fields: [restaurant_id], references: [id], onDelete: Cascade)
  settings      Json       @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("reservation_settings")
}

model ReservationQuery {
  id          String   @id @default(cuid())
  date        DateTime
  time        String
  name        String
  email       String
  message     String
  phoneNumber String?
  status      String   @default("pending")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  restaurant    Restaurant @relation(fields: [restaurant_id], references: [id], onDelete: Cascade)
  restaurant_id String     @db.Uuid

  @@index([status])
  @@index([createdAt])
  @@index([restaurant_id])
}

model RestaurantView {
  id         String   @id @default(uuid()) @db.Uuid
  ip_hash    String
  user_agent String?
  createdAt  DateTime @default(now()) @map("created_at")

  restaurant    Restaurant @relation(fields: [restaurant_id], references: [id], onDelete: Cascade)
  restaurant_id String     @db.Uuid

  @@map("restaurant_views")
}

model Event {
  id            String   @id @default(uuid()) @db.Uuid
  restaurant_id String   @db.Uuid
  title         String
  description   String?
  date          DateTime
  ticket_url    String?
  sort_order    Int      @default(0)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")

  restaurant Restaurant @relation(fields: [restaurant_id], references: [id], onDelete: Cascade)

  @@map("events")
}

model FaqCategory {
  id            String   @id @default(uuid()) @db.Uuid
  restaurant_id String   @db.Uuid
  name          String
  description   String?
  sort_order    Int      @default(0)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")

  faqs       Faq[]
  restaurant Restaurant @relation(fields: [restaurant_id], references: [id], onDelete: Cascade)

  @@map("faq_categories")
}

model Faq {
  id          String   @id @default(uuid()) @db.Uuid
  category_id String   @db.Uuid
  question    String
  answer      String
  sort_order  Int      @default(0)
  is_featured Boolean  @default(false)
  view_count  Int?     @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  category FaqCategory @relation(fields: [category_id], references: [id], onDelete: Cascade)

  @@map("faqs")
}

model Link {
  id            String   @id @default(uuid()) @db.Uuid
  restaurant_id String   @db.Uuid
  title         String
  icon_slug     String   @default("link")
  url           String
  sort_order    Int      @default(0)
  show_icon     Boolean? @default(true)
  createdAt     DateTime @default(now()) @map("created_at")

  views      LinkView[]
  restaurant Restaurant @relation(fields: [restaurant_id], references: [id], onDelete: Cascade)
  qrCodes    qr_codes[]

  @@map("links")
}

model LinkView {
  id         String   @id @default(uuid()) @db.Uuid
  link_id    String   @db.Uuid
  ip_hash    String
  user_agent String?
  createdAt  DateTime @default(now()) @map("created_at")

  link Link @relation(fields: [link_id], references: [id], onDelete: Cascade)

  @@map("link_views")
}

model MenuCategory {
  id                 String   @id @default(uuid()) @db.Uuid
  restaurant_id      String   @db.Uuid
  name               String
  description        String?
  show_in_quick_menu Boolean  @default(false)
  sort_order         Int      @default(0)
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @default(now()) @updatedAt @map("updated_at")

  items      MenuItem[]
  restaurant Restaurant @relation(fields: [restaurant_id], references: [id], onDelete: Cascade)

  @@map("menu_categories")
}

model MenuItem {
  id                 String   @id @default(uuid()) @db.Uuid
  category_id        String   @db.Uuid
  name               String
  description        String?
  image              String?
  price              Float
  sort_order         Int      @default(0)
  show_in_quick_menu Boolean  @default(false)
  allergens          String[] @default([])
  is_halal           Boolean? @default(false)
  allergen_info      String?
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @default(now()) @updatedAt @map("updated_at")

  category  MenuCategory @relation(fields: [category_id], references: [id], onDelete: Cascade)
  OrderItem OrderItem[]
  addons    Json?        @default("[]")

  @@map("menu_items")
}

model Review {
  id            String   @id @default(uuid()) @db.Uuid
  restaurant_id String   @db.Uuid
  rating        Int
  comment       String?
  author_name   String
  time          DateTime @default(now())
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")

  restaurant Restaurant @relation(fields: [restaurant_id], references: [id], onDelete: Cascade)

  @@map("reviews")
}

enum qr_code_type {
  restaurant_page
  link
  custom
}

model qr_codes {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  restaurant_id   String          @db.Uuid
  restaurant      Restaurant      @relation(fields: [restaurant_id], references: [id], onDelete: Cascade)
  name            String          @db.VarChar
  type            qr_code_type
  target_url      String          @db.Text
  link_id         String?         @db.Uuid
  link            Link?           @relation(fields: [link_id], references: [id], onDelete: Cascade)
  custom_url      String?         @db.Text
  size            Int             @default(300)
  color           String          @default("#000000") @db.VarChar
  include_logo    Boolean         @default(true)
  include_frame   Boolean         @default(true)
  frame_text      String?         @db.VarChar
  qr_data_url     String?         @db.Text
  scan_count      Int             @default(0)
  is_active       Boolean         @default(true)
  last_scanned_at DateTime?       @db.Timestamptz
  created_at      DateTime        @default(now()) @db.Timestamptz
  updated_at      DateTime        @default(now()) @db.Timestamptz
  qr_code_scans   qr_code_scans[]

  @@index([restaurant_id], name: "idx_qr_codes_restaurant_id")
  @@index([link_id], name: "idx_qr_codes_link_id")
  @@index([type], name: "idx_qr_codes_type")
  @@index([is_active], name: "idx_qr_codes_is_active")
  @@index([created_at], name: "idx_qr_codes_created_at")
}

model qr_code_scans {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  qr_code_id String   @db.Uuid
  qr_code    qr_codes @relation(fields: [qr_code_id], references: [id], onDelete: Cascade)
  ip_hash    String   @db.VarChar
  user_agent String?  @db.Text
  referer    String?  @db.Text
  scanned_at DateTime @default(now()) @db.Timestamptz

  @@index([qr_code_id], name: "idx_qr_code_scans_qr_code_id")
  @@index([scanned_at], name: "idx_qr_code_scans_scanned_at")
  @@index([ip_hash], name: "idx_qr_code_scans_ip_hash")
}

model Order {
  id                    String        @id @default(uuid()) @db.Uuid
  user_id               String?       @db.Uuid // Made optional for guest orders
  restaurant_id         String        @db.Uuid
  stripe_payment_intent String        @unique
  stripe_session_id     String?       @unique
  order_number          String        @unique
  customer_name         String?
  customer_email        String?
  customer_phone        String?
  preferredISO          String?
  // Address 
  delivery_address      String?
  street                String?
  city                  String?
  state                 String?
  postal_code           String?
  country               String?
  latitude              Float?
  longitude             Float?
  notes                 String?
  // ---- 
  order_type            String        @default("pickup") // pickup, delivery
  status                OrderStatus   @default(pending)
  payment_status        PaymentStatus @default(pending)
  subtotal              Float
  tax_amount            Float
  delivery_fee          Float         @default(0)
  total_amount          Float
  special_instructions  String?
  estimated_ready_time  DateTime?
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @default(now()) @updatedAt @map("updated_at")

  user       User?       @relation(fields: [user_id], references: [id], onDelete: Cascade)
  restaurant Restaurant  @relation(fields: [restaurant_id], references: [id], onDelete: Cascade)
  items      OrderItem[]

  @@map("orders")
}

model OrderItem {
  id               String    @id @default(uuid()) @db.Uuid
  order_id         String    @db.Uuid
  menu_item_id     String?   @db.Uuid
  name             String
  description      String?
  price            Float
  quantity         Int
  item_total       Float
  special_requests String?
  allergens        String[]
  addons           Json?     @default("[]")
  order            Order     @relation(fields: [order_id], references: [id], onDelete: Cascade)
  menuItem         MenuItem? @relation(fields: [menu_item_id], references: [id], onDelete: Cascade)

  @@map("order_items")
}

// Reservation Tables 
model Area {
  id            String  @id @default(uuid()) @db.Uuid
  name          String
  description   String?
  active        Boolean @default(true)
  restaurant_id String  @db.Uuid
  sort_order    Int     @default(0)

  // Relations
  restaurant Restaurant @relation(fields: [restaurant_id], references: [id], onDelete: Cascade)
  tables     Table[]

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([restaurant_id])
  @@index([active])
  @@map("areas")
}

model Table {
  id             String      @id @default(uuid()) @db.Uuid
  restaurant_id  String      @db.Uuid
  area_id        String      @db.Uuid
  table_number   String
  name           String? // Optional display name
  capacity       Int
  min_party_size Int         @default(1)
  max_party_size Int         @default(8)
  status         TableStatus @default(ACTIVE)
  sort_order     Int         @default(0)
  metadata       Json? // Additional table properties

  // Relations
  restaurant         Restaurant         @relation(fields: [restaurant_id], references: [id], onDelete: Cascade)
  area               Area               @relation(fields: [area_id], references: [id], onDelete: Cascade)
  table_reservations TableReservation[]

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([restaurant_id, table_number])
  @@index([restaurant_id])
  @@index([area_id])
  @@index([status])
  @@index([capacity])
  @@index([min_party_size, max_party_size])
  @@map("tables")
}

model Reservation {
  id            String @id @default(uuid()) @db.Uuid
  restaurant_id String @db.Uuid

  // Customer information
  customer_name  String
  customer_email String
  customer_phone String?

  // Reservation timing - ONLY arrival time stored
  arrival_time               DateTime
  estimated_duration_minutes Int? // Calculated from settings

  // Reservation details
  party_size       Int
  special_requests String?
  preferred_area   String?

  // Status tracking
  status        ReservationStatus @default(PENDING)
  source        ReservationSource @default(ONLINE)
  reminder_sent Boolean           @default(false)

  // Timestamps for lifecycle tracking
  confirmed_at DateTime?
  seated_at    DateTime?
  completed_at DateTime?
  cancelled_at DateTime?
  no_show_at   DateTime?

  // Relations
  restaurant         Restaurant         @relation(fields: [restaurant_id], references: [id], onDelete: Cascade)
  payment            Payment?
  table_reservations TableReservation[]

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Critical indexes for performance
  @@index([restaurant_id, arrival_time])
  @@index([arrival_time])
  @@index([status])
  @@index([customer_email])
  @@index([restaurant_id, status, arrival_time])
  @@index([arrival_time, status])
  @@index([createdAt])
  @@map("reservations")
}

model TableReservation {
  id             String   @id @default(uuid()) @db.Uuid
  reservation_id String   @db.Uuid
  table_id       String   @db.Uuid
  assigned_by    String? // Staff ID or name
  assigned_at    DateTime @default(now())

  // Relations
  reservation Reservation @relation(fields: [reservation_id], references: [id], onDelete: Cascade)
  table       Table       @relation(fields: [table_id], references: [id], onDelete: Cascade)

  @@unique([reservation_id, table_id])
  @@index([reservation_id])
  @@index([table_id])
  @@index([assigned_at])
  @@map("table_reservations")
}

enum TableStatus {
  ACTIVE
  INACTIVE
}

model Payment {
  id                       String                   @id @default(uuid()) @db.Uuid
  reservation_id           String                   @unique @db.Uuid
  amount                   Decimal                  @db.Decimal(10, 2)
  currency                 String                   @default("EUR")
  payment_method           String? // card, cash, etc.
  transaction_id           String? // For online payments
  stripe_payment_intent_id String? // For online payments
  stripe_session_id        String? // For online payments
  refund_id                String? // For refunds
  status                   ReservationPaymentStatus @default(PENDING)
  paid_at                  DateTime?
  refunded_at              DateTime?

  // Deposit information
  deposit_amount     Decimal? @db.Decimal(10, 2)
  deposit_percentage Float? // Percentage of total

  // Relations
  reservation Reservation @relation(fields: [reservation_id], references: [id], onDelete: Cascade)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([paid_at])
  @@index([transaction_id])
  @@map("payments")
}

enum ReservationPaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  SEATED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum ReservationSource {
  ONLINE
  PHONE
  WALK_IN
  PARTNER
}

model NotificationVerificationCode {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @unique
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())
}
